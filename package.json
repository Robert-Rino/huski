{
  "name": "huski-pi",
  "version": "0.3.0",
  "description": "Reusable pi package for Huski workflows, skills, extensions, and web tools.",
  "license": "MIT",
  "type": "module",
  "keywords": [
    "pi-package"
  ],
  "files": [
    "extensions",
